&pinctrl {
	audiopwm {
		audiopwm_loutn: audiopwm-loutn {
			rockchip,pins = <1 RK_PA1 6 &pcfg_pull_none>;
		};

		audiopwm_loutp: audiopwm-loutp {
			rockchip,pins = <1 RK_PA0 6 &pcfg_pull_none>;
		};

		audiopwm_routn: audiopwm-routn {
			rockchip,pins = <1 RK_PA7 4 &pcfg_pull_none>;
		};

		audiopwm_routp: audiopwm-routp {
			rockchip,pins = <1 RK_PA6 4 &pcfg_pull_none>;
		};
	};

	cam {
		cam_clkout0: cam-clkout0 {
			rockchip,pins = <4 RK_PA7 1 &pcfg_pull_none>;
		};

		cam_clkout1: cam-clkout1 {
			rockchip,pins = <4 RK_PB2 1 &pcfg_pull_none>;
		};

		camera_pwr: camera-pwr {
			rockchip,pins = <3 RK_PD1 0 &pcfg_pull_none>;
		};
	};

	can0 {
		can0m1_pins: can0m1-pins {
			rockchip,pins = <2 RK_PA2 4 &pcfg_pull_none>,
					<2 RK_PA1 4 &pcfg_pull_none>;
		};
	};

	can1 {
		can1m1_pins: can1m1-pins {
			rockchip,pins = <4 RK_PC4 3 &pcfg_pull_none>,
					<4 RK_PC5 3 &pcfg_pull_none>;
		};
	};

	can2 {
		can2m1_pins: can2m1-pins {
			rockchip,pins = <2 RK_PB1 4 &pcfg_pull_none>,
					<2 RK_PB2 4 &pcfg_pull_none>;
		};
	};

	clk32k {
		clk32k_out0: clk32k-out0 {
			rockchip,pins = <0 RK_PB0 2 &pcfg_pull_none>;
		};
	};

	hdmitx {
		hdmitxm0_cec: hdmitxm0-cec {
			rockchip,pins = <4 RK_PD3 1 &pcfg_pull_none>;
		};

		hdmitx_scl: hdmitx-scl {
			rockchip,pins = <4 RK_PD1 1 &pcfg_pull_none>;
		};

		hdmitx_sda: hdmitx-sda {
			rockchip,pins = <4 RK_PD2 1 &pcfg_pull_none>;
		};
	};

	i2c1 {
		/omit-if-no-ref/
		i2c1_xfer: i2c1-xfer {
			rockchip,pins = <0 RK_PB3 1 &pcfg_pull_none_smt>,
					<0 RK_PB4 1 &pcfg_pull_none_smt>;
		};
	};

	i2c2 {
		/omit-if-no-ref/
		i2c2m1_xfer: i2c2m1-xfer {
			rockchip,pins = <4 RK_PB5 1 &pcfg_pull_none_smt>,
					<4 RK_PB4 1 &pcfg_pull_none_smt>;
		};
	};

	i2c3 {
		/omit-if-no-ref/
		i2c3m0_xfer: i2c3m0-xfer {
			rockchip,pins = <1 RK_PA1 1 &pcfg_pull_none_smt>,
					<1 RK_PA0 1 &pcfg_pull_none_smt>;
		};
	};

	i2c4 {
		/omit-if-no-ref/
		i2c4m0_xfer: i2c4m0-xfer {
			rockchip,pins = <4 RK_PB3 1 &pcfg_pull_none_smt>,
					<4 10 1 &pcfg_pull_none_smt>;
		};
	};

	i2c5 {
		/omit-if-no-ref/
		i2c5m0_xfer: i2c5m0-xfer {
			rockchip,pins = <3 RK_PB3 4 &pcfg_pull_none_smt>,
					<3 RK_PB4 4 &pcfg_pull_none_smt>;
		};
	};

	lcdc {
		lcdc_ctl: lcdc-ctl {
			rockchip,pins = <3 RK_PA0 1 &pcfg_pull_none>,
					<2 RK_PD0 1 &pcfg_pull_none>,
					<2 RK_PD1 1 &pcfg_pull_none>,
					<2 RK_PD2 1 &pcfg_pull_none>,
					<2 RK_PD3 1 &pcfg_pull_none>,
					<2 RK_PD4 1 &pcfg_pull_none>,
					<2 RK_PD5 1 &pcfg_pull_none>,
					<2 RK_PD6 1 &pcfg_pull_none>,
					<2 RK_PD7 1 &pcfg_pull_none>,
					<3 RK_PA1 1 &pcfg_pull_none>,
					<3 RK_PA2 1 &pcfg_pull_none>,
					<3 RK_PA3 1 &pcfg_pull_none>,
					<3 RK_PA4 1 &pcfg_pull_none>,
					<3 RK_PA5 1 &pcfg_pull_none>,
					<3 RK_PA6 1 &pcfg_pull_none>,
					<3 RK_PA7 1 &pcfg_pull_none>,
					<3 RK_PB0 1 &pcfg_pull_none>,
					<3 RK_PB1 1 &pcfg_pull_none>,
					<3 RK_PB2 1 &pcfg_pull_none>,
					<3 RK_PB3 1 &pcfg_pull_none>,
					<3 RK_PB4 1 &pcfg_pull_none>,
					<3 RK_PB5 1 &pcfg_pull_none>,
					<3 RK_PB6 1 &pcfg_pull_none>,
					<3 RK_PB7 1 &pcfg_pull_none>,
					<3 RK_PC0 1 &pcfg_pull_none>,
					<3 RK_PC3 1 &pcfg_pull_none>,
					<3 RK_PC1 1 &pcfg_pull_none>,
					<3 RK_PC2 1 &pcfg_pull_none>;
		};
	};

	pmic {
		pmic_int: pmic_int {
			rockchip,pins = <0 RK_PA3 0 &pcfg_pull_up>;
		};

		soc_slppin_gpio: soc_slppin_gpio {
			rockchip,pins = <0 RK_PA2 0 &pcfg_output_low_pull_down>;
		};

		soc_slppin_slp: soc_slppin_slp {
			rockchip,pins = <0 RK_PA2 1 &pcfg_pull_up>;
		};

		soc_slppin_rst: soc_slppin_rst {
			rockchip,pins = <0 RK_PA2 2 &pcfg_pull_none>;
		};
	};

	scr {
		scr_pins: scr-pins {
			rockchip,pins = <1 RK_PA2 3 &pcfg_pull_none>,
					<1 RK_PA7 3 &pcfg_pull_up>,
					<1 RK_PA3 3 &pcfg_pull_up>,
					<1 RK_PA5 3 &pcfg_pull_none>;
		};
	};

	sdmmc0 {
		/omit-if-no-ref/
		sdmmc0_bus4: sdmmc0-bus4 {
			rockchip,pins = <1 RK_PD5 1 &pcfg_pull_up_drv_level_2>,
					<1 RK_PD6 1 &pcfg_pull_up_drv_level_2>,
					<1 RK_PD7 1 &pcfg_pull_up_drv_level_2>,
					<2 RK_PA0 1 &pcfg_pull_up_drv_level_2>;
		};

		/omit-if-no-ref/
		sdmmc0_clk: sdmmc0-clk {
			rockchip,pins = <2 RK_PA2 1 &pcfg_pull_up_drv_level_2>;
		};

		/omit-if-no-ref/
		sdmmc0_cmd: sdmmc0-cmd {
			rockchip,pins = <2 RK_PA1 1 &pcfg_pull_up_drv_level_2>;
		};

		/omit-if-no-ref/
		sdmmc0_det: sdmmc0-det {
			rockchip,pins = <0 RK_PA4 1 &pcfg_pull_up>;
		};
	};

	sdmmc1 {
		/omit-if-no-ref/
		sdmmc1_bus4: sdmmc1-bus4 {
			rockchip,pins = <2 RK_PA3 1 &pcfg_pull_up_drv_level_2>,
					<2 RK_PA4 1 &pcfg_pull_up_drv_level_2>,
					<2 RK_PA5 1 &pcfg_pull_up_drv_level_2>,
					<2 RK_PA6 1 &pcfg_pull_up_drv_level_2>;
		};

		/omit-if-no-ref/
		sdmmc1_clk: sdmmc1-clk {
			rockchip,pins = <2 RK_PB0 1 &pcfg_pull_up_drv_level_2>;
		};

		/omit-if-no-ref/
		sdmmc1_cmd: sdmmc1-cmd {
			rockchip,pins = <2 RK_PA7 1 &pcfg_pull_up_drv_level_2>;
		};
	};

	sdio-pwrseq {
		wifi_enable_h: wifi-enable-h {
			rockchip,pins = <2 RK_PB1 0 &pcfg_pull_none>;
		};
	};

	spdif {
		spdifm0_tx: spdifm0-tx {
			rockchip,pins = <1 RK_PA4 4 &pcfg_pull_none>;
		};
	};

	tsadc {
		tsadc_shutorg: tsadc-shutorg {
			rockchip,pins = <0 RK_PA1 2 &pcfg_pull_none>;
		};
	};

	uart0 {
		/omit-if-no-ref/
		uart0_xfer: uart0-xfer {
			rockchip,pins = <0 RK_PB2 3 &pcfg_pull_up>,
					<0 RK_PB3 3 &pcfg_pull_up>;
		};
	};

	uart1 {
		/omit-if-no-ref/
		uart1m0_xfer: uart1m0-xfer {
			rockchip,pins = <2 RK_PB3 2 &pcfg_pull_up>,
					<2 RK_PB4 2 &pcfg_pull_up>;
		};

		/omit-if-no-ref/
		uart1m0_ctsn: uart1m0-ctsn {
			rockchip,pins = <2 RK_PB6 2 &pcfg_pull_none>;
		};

		/omit-if-no-ref/
		uart1m0_rtsn: uart1m0-rtsn {
			rockchip,pins = <2 RK_PB5 2 &pcfg_pull_none>;
		};
	};

	uart2 {
		/omit-if-no-ref/
		uart2m0_xfer: uart2m0-xfer {
			rockchip,pins = <0 RK_PC0 1 &pcfg_pull_up>,
					<0 RK_PC1 1 &pcfg_pull_up>;
		};
	};

	uart3 {
		/omit-if-no-ref/
		uart3m1_xfer: uart3m1-xfer {
			rockchip,pins = <3 RK_PC2 4 &pcfg_pull_up>,
					<3 RK_PC1 4 &pcfg_pull_up>;
		};
	};

	uart4 {
		/omit-if-no-ref/
		uart4m1_xfer: uart4m1-xfer {
			rockchip,pins = <3 RK_PB1 4 &pcfg_pull_up>,
					<3 RK_PB2 4 &pcfg_pull_up>;
		};
	};

	uart5 {
		/omit-if-no-ref/
		uart5m0_xfer: uart5m0-xfer {
			rockchip,pins = <2 RK_PA1 3 &pcfg_pull_up>,
					<2 RK_PA2 3 &pcfg_pull_up>;
		};
	};

	uart6 {
		/omit-if-no-ref/
		uart6m0_xfer: uart6m0-xfer {
			rockchip,pins = <2 RK_PA3 3 &pcfg_pull_up>,
					<2 RK_PA4 3 &pcfg_pull_up>;
		};
	};

	uart7 {
		/omit-if-no-ref/
		uart7m0_xfer: uart7m0-xfer {
			rockchip,pins = <2 RK_PA5 3 &pcfg_pull_up>,
					<2 RK_PA6 3 &pcfg_pull_up>;
		};
	};

	uart8 {
		/omit-if-no-ref/
		uart8m0_xfer: uart8m0-xfer {
			rockchip,pins = <2 RK_PD6 2 &pcfg_pull_up>,
					<2 RK_PD5 3 &pcfg_pull_up>;
		};
	};

	uart9 {
		/omit-if-no-ref/
		uart9m0_xfer: uart9m0-xfer {
			rockchip,pins = <2 RK_PA7 3 &pcfg_pull_up>,
					<2 RK_PB0 3 &pcfg_pull_up>;
		};
	};

	usb {
		vcc5v0_host_en: vcc5v0-host-en {
			rockchip,pins = <0 RK_PA6 0 &pcfg_pull_none>;
		};

		vcc5v0_otg_en: vcc5v0-otg-en {
			rockchip,pins = <0 RK_PA5 0 &pcfg_pull_none>;
		};
	};

	wifi {
		wifi_pwr: wifi-pwr {
			rockchip,pins = <1 RK_PA0 0 &pcfg_pull_none>;
		};
	};

	wireless-wlan {
		wifi_host_wake_irq: wifi-host-wake-irq {
			rockchip,pins = <2 RK_PB2 0 &pcfg_pull_down>;
		};
	};

	wireless-bluetooth {
		uart1_gpios: uart1-gpios {
			rockchip,pins = <2 RK_PB5 0 &pcfg_pull_none>;
		};
	};

	headphone {
		hp_det: hp-det {
			rockchip,pins = <3 RK_PA1 0 &pcfg_pull_down>;
		};
	};

	lcd0 {
		lcd0_rst_gpio: lcd0-rst-gpio {
			rockchip,pins = <4 RK_PD5 0 &pcfg_pull_none>;
		};
	};

	lcd1 {
		lcd1_rst_gpio: lcd1-rst-gpio {
			rockchip,pins = <0 RK_PD4 0 &pcfg_pull_none>;
		};
	};

	pcie {
		pcie_pwr_en: pcie-pwr-en {
			rockchip,pins = <0 RK_PC7 0 &pcfg_pull_none>;
		};

		evb_pcie20m1_pins: pcie20m1-pins {
			rockchip,pins = <4 RK_PD1 0 &pcfg_pull_none>;
		};
	};

	edp {
		edp_backlight_on: edp-backlight-on {
			rockchip,pins = <0 RK_PC1 0 &pcfg_pull_none>;
		};

		edp_bk_pwm_gpio: edp-bk-pwm-gpio {
			rockchip,pins = <0 RK_PB5 0 &pcfg_pull_none>;
		};

		edp_vdd_en_gpio: edp-vdd-en-gpio {
			rockchip,pins = <0 RK_PC4 0 &pcfg_pull_none>;
		};
	};

	rtc {
		rtc_int: rtc-int {
			rockchip,pins = <0 RK_PB2 0 &pcfg_pull_up>;
		};
	};

	mcu-watchdog {
		feed_gpios: fees-gpios {
			rockchip,pins = <4 RK_PB1 0 &pcfg_pull_none>;
		};
	};

	touch {
		touch_gpio: touch-gpio {
			rockchip,pins = <0 RK_PB5 0 &pcfg_pull_up>,
					<0 RK_PB6 0 &pcfg_pull_none>;
		};
	};

	mxc6655xa {
		mxc6655xa_irq_gpio: mxc6655xa_irq_gpio {
			rockchip,pins = <3 RK_PC3 0 &pcfg_pull_none>;
		};
	};

	tr5511 {
		tr5511_pin: tr5511-pin {
			rockchip,pins = <3 RK_PA3 0 &pcfg_pull_none>;
		};
	};
};
